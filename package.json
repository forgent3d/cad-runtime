{
  "name": "@forgent3d/cad-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Shared CAD runtime protocol, types, and pure utilities for Forgent3D cloud services.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "python",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
